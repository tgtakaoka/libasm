	m68k-elf-ld --entry=0 -o $(^:.gas=.o) $(^:.gas=.p)
	m68k-elf-objcopy -I elf32-m68k -O srec --srec-len=16 \
		--adjust-section-vma .text=0x10000 $(^:.gas=.o) /dev/stdout \
	| tr -d '\015' > $(^:.gas=.s28)
