	m6811-elf-ld -m m68hc11elf --entry=0 -o $(^:.gas=.o) $(^:.gas=.p)
	m6811-elf-objcopy -I elf32-m68hc11 -O srec --srec-len=16 \
	        --change-section-lma .text=0x0100 $(^:.gas=.o) /dev/stdout \
	| tr -d '\015' > $(^:.gas=.s19)
	m6811-elf-objdump -m m68hc11 -D $(^:.gas=.s19) > $(^:.gas=.dis)

