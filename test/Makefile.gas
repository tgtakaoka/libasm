# GNU assembler rules

# PDP-11 targets.
#
# binutils 2.46.1's --target-help advertises -mt11/-mj11, but the option
# table in this build only contains the kd11/ka11/kb11 entries, so those
# flags are rejected. Pass each instruction-set extension explicitly per
# the J-11 / T-11 architecture handbooks until upstream lands the CPU
# aliases:
#   T-11: limited EIS (incl. RTT), MTPS/MFPS, MFPT
#   J-11: full EIS,  MTPS/MFPS, MFPT, SPL, CSM, TSTSET/WRTLCK
#          (-mmultiproc), and FP-11 floating point.
T11_FLAGS = -mno-extensions -mlimited-eis -mmxps -mmfpt
J11_FLAGS = -mno-extensions -meis -mmxps -mmfpt -mspl -mcsm -mmultiproc -mfpp

gas-%_t11.hex: %_t11.gas
	pdp11-aout-as $(T11_FLAGS) --warn -o $(^:.gas=.p) -al=$(^:.gas=.lst) $^
	pdp11-aout-ld --entry=0 -section-start=.text=0 -o $(^:.gas=.o) $(^:.gas=.p)
	pdp11-aout-objcopy -I a.out-pdp11 -O ihex $(^:.gas=.o) /dev/stdout \
	| tr -d '\015' > $(^:.gas=.hex)
	pdp11-aout-objdump -m pdp11 -D $(^:.gas=.hex) > $(^:.gas=.dis)

gas-%_j11.hex: %_j11.gas
	pdp11-aout-as $(J11_FLAGS) --warn -o $(^:.gas=.p) -al=$(^:.gas=.lst) $^
	pdp11-aout-ld --entry=0 -section-start=.text=0 -o $(^:.gas=.o) $(^:.gas=.p)
	pdp11-aout-objcopy -I a.out-pdp11 -O ihex $(^:.gas=.o) /dev/stdout \
	| tr -d '\015' > $(^:.gas=.hex)
	pdp11-aout-objdump -m pdp11 -D $(^:.gas=.hex) > $(^:.gas=.dis)

# Z8001 target
gas-%_z8001.hex: %_z8001.gas
	z8k-coff-as --warn -o $(^:.gas=.p) -al=$(^:.gas=.lst) $^
	z8k-coff-ld -m z8001 --entry=0 -o $(^:.gas=.o) $(^:.gas=.p) \
		--section-start=text=0x010000 \
		--section-start=bss1=0x0A1234 \
		--section-start=bss2=0x0B5678
	z8k-coff-objcopy -I coff-z8k -O ihex $(^:.gas=.o) /dev/stdout \
		--adjust-section-vma .text=0x010000 \
	| tr -d '\015' > $(^:.gas=.hex)
	z8k-coff-objdump -m z8001 -D $(^:.gas=.hex) > $(^:.gas=.dis)

# Z8002 target
gas-%_z8002.hex: %_z8002.gas
	z8k-coff-as --warn -o $(^:.gas=.p) -al=$(^:.gas=.lst) $^
	z8k-coff-ld -m z8002 --entry=0 -o $(^:.gas=.o) $(^:.gas=.p) \
		--section-start=text=0x1000 \
		--section-start=bss1=0x1234 \
		--section-start=bss2=0x5678
	z8k-coff-objcopy -I coff-z8k -O ihex $(^:.gas=.o) /dev/stdout \
		--adjust-section-vma .text=0x1000 \
	| tr -d '\015' > $(^:.gas=.hex)
	z8k-coff-objdump -m z8002 -D $(^:.gas=.hex) > $(^:.gas=.dis)

# NS32032 target
gas-%_ns32032.hex: %_ns32032.gas
	ns32k-openbsd-as -m32032 --warn -o $(^:.gas=.o) -al=$(^:.gas=.lst) $^
	ns32k-openbsd-objcopy -I a.out-ns32k-netbsd -O ihex -j .text \
		--adjust-section-vma .text=0x10000 $(^:.gas=.o) /dev/stdout \
	| tr -d '\015' > $(^:.gas=.hex)
	ns32k-openbsd-objdump -m ns32k:32032 -D $(^:.gas=.hex) > $(^:.gas=.dis)

