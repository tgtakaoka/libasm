;### Data Transfer
;### Move
        mov     eax,ecx
        mov     edx,ebx
        mov     esp,ebp
        mov     [esi],esi
        mov     [0x1234],edi
        mov     [edi-0x34],eax
        mov     [ebp+0x1234],ecx
        mov     [ebx+esi],edx
        mov     [ebx+edi+0x34],ebx
        mov     [ebp+esi+0x1234],esp
        mov     esi,[esi]
        mov     edi,[0x1234]
        mov     eax,[edi-0x34]
        mov     ecx,[ebp+0x1234]
        mov     edx,[ebx+esi]
        mov     ebx,[ebx+edi+0x34]
        mov     esp,[ebp+esi+0x1234]
        mov     eax,0x12345678
        mov     ecx,0x12345678
        mov     dword ptr [esi],0x12345678
        mov     dword ptr [0x1234],0x12345678
        mov     dword ptr [edi+0x34],0x12345678
        mov     dword ptr [ebp+0x1234],0x12345678
        mov     dword ptr [ebx+esi],0x12345678
        mov     dword ptr [ebx+edi-0x34],0x12345678
        mov     dword ptr [ebp+esi+0x89AB],0x12345678
        mov     eax,[0x1234]
        mov     [0x1234],eax
        mov     eax,es
        mov     [esi],cs
        mov     [0x89AB],ss
        mov     [edi-0x34],ds
        mov     [ebp+0x1234],es
        mov     [ebx+esi],cs
        mov     [ebx+edi+0x34],ss
        mov     [ebp+esi+0x1234],ds
        mov     es,eax
        mov     cs,[esi]
        mov     ss,[0x1234]
        mov     ds,[edi-0x34]
        mov     es,[ebp+0x1234]
        mov     cs,[ebx+esi]
        mov     ss,[ebx+edi+0x34]
        mov     ds,[ebp+esi+0x1234]
        mov     fs,ax
        mov     gs,[si]
        mov     fs,[0x1234]
        mov     gs,[di-0x34]
        mov     fs,[bp+0x1234]
        mov     gs,[bx+si]
        mov     fs,[bx+di+0x34]
        mov     gs,[bp+si+0x1234]
        mov     gs,[esi]
        mov     fs,[0x1234]
        mov     gs,[edi-0x34]
        mov     fs,[ebp+0x1234]
        mov     gs,[ebx+esi]
        mov     fs,[ebx+edi+0x34]
        mov     gs,[ebp+esi+0x1234]
;### Move to/from special registers
        mov     eax,cr0
        mov     ecx,cr2
        mov     edx,cr3
        mov     ebx,dr0
        mov     esi,tr6
        mov     edi,tr7
        mov     cr0,esp
        mov     cr2,ebp
        mov     cr3,eax
        mov     dr0,eax
        mov     dr1,ecx
        mov     tr6,edx
        mov     tr7,ebx
;### Push data onto stack
        pushd   0x12345678
        push    ebp
        push    [esi]
        push    [0x1234]
        push    [edi-0x34]
        push    [ebp+0x1234]
        push    [ebx+esi]
        push    [ebx+edi+0x34]
        push    [ebp+esi+0x1234]
        push    es
        push    cs
        push    ss
        push    ds
        push    fs
        push    gs
;### Pop data from stack
        pop     ebp
        pop     [esi]
        pop     [0x1234]
        pop     [edi-0x34]
        pop     [ebp+0x1234]
        pop     [ebx+esi]
        pop     [ebx+edi+0x34]
        pop     [ebp+esi+0x1234]
        pop     es
;###    pop     cs
        pop     ss
        pop     ds
        pop     fs
        pop     gs
;### Exchange data
        xchg    eax,ebp
        xchg    [esi],ecx
        xchg    [0x1234],edx
        xchg    [edi-0x34],ebx
        xchg    [ebp+0x1234],esp
        xchg    [ebx+esi],ebp
        xchg    [ebx+edi+0x34],esi
        xchg    [ebp+esi+0x1234],edi
;### Input from port
        in      eax,0x34
        in      eax,dx
;### Output to port
        out     0x34,eax
        out     dx,eax
;### Load effective address
        lea     ecx,[esi]
        lea     edx,[0x1234]
        lea     ebx,[edi-0x34]
        lea     esp,[ebp+0x1234]
        lea     ebp,[ebx+esi]
        lea     esi,[ebx+edi+0x34]
        lea     edi,[ebp+esi+0x1234]
;### Load pointer uesing DS
        lds     ecx,[esi]
        lds     edx,[0x1234]
        lds     ebx,[edi-0x34]
        lds     esp,[ebp+0x1234]
        lds     ebp,[ebx+esi]
        lds     esi,[ebx+edi+0x34]
        lds     edi,[ebp+esi+0x1234]
;### Load ES with pointer
        les     ecx,[esi]
        les     edx,[0x1234]
        les     ebx,[edi-0x34]
        les     esp,[ebp+0x1234]
        les     ebp,[ebx+esi]
        les     esi,[ebx+edi+0x34]
        les     edi,[ebp+esi+0x1234]
;### Load FS with pointer
        lfs     cx,[si]
        lfs     dx,[0x1234]
        lfs     bx,[di-0x34]
        lfs     sp,[bp+0x1234]
        lfs     bp,[bx+si]
        lfs     si,[bx+di+0x34]
        lfs     di,[bp+si+0x1234]
        lfs     ecx,[esi]
        lfs     edx,[0x1234]
        lfs     ebx,[edi-0x34]
        lfs     esp,[ebp+0x1234]
        lfs     ebp,[ebx+esi]
        lfs     esi,[ebx+edi+0x34]
        lfs     edi,[ebp+esi+0x1234]
;### Load GS with pointer
        lgs     cx,[si]
        lgs     dx,[0x1234]
        lgs     bx,[di-0x34]
        lgs     sp,[bp+0x1234]
        lgs     bp,[bx+si]
        lgs     si,[bx+di+0x34]
        lgs     di,[bp+si+0x1234]
        lgs     ecx,[esi]
        lgs     edx,[0x1234]
        lgs     ebx,[edi-0x34]
        lgs     esp,[ebp+0x1234]
        lgs     ebp,[ebx+esi]
        lgs     esi,[ebx+edi+0x34]
        lgs     edi,[ebp+esi+0x1234]
;### Push register onto stack
        pushfd
        pushad
;### Pop register from stack
        popfd
        popad
;### Arithmetic
;### Add
        add     [esi],dh
        add     [0x1234],bh
        add     [edi-0x34],al
        add     [ebp+0x1234],cl
        add     [ebx+esi],dl
        add     [ebx+edi+0x34],bl
        add     [ebp+esi+0x1234],ah
        add     dh,[esi]
        add     bh,[0x1234]
        add     al,[edi-0x34]
        add     cl,[ebp+0x1234]
        add     dl,[ebx+esi]
        add     bl,[ebx+edi+0x34]
        add     ah,[ebp+esi+0x1234]
        add     eax,ecx
        add     edx,ebx
        add     esp,ebp
        add     [esi],esi
        add     [0x1234],edi
        add     [edi-0x34],eax
        add     [ebp+0x1234],ecx
        add     [ebx+esi],edx
        add     [ebx+edi+0x34],ebx
        add     [ebp+esi+0x1234],esp
        add     esi,[esi]
        add     edi,[0x1234]
        add     eax,[edi-0x34]
        add     ecx,[ebp+0x1234]
        add     edx,[ebx+esi]
        add     ebx,[ebx+edi+0x34]
        add     esp,[ebp+esi+0x1234]
        add     eax,0x12345678
        add     ecx,0x12345678
        add     byte ptr [esi],0x56
        add     byte ptr [0x1234],0x56
        add     byte ptr [edi-0x34],0x56
        add     byte ptr [ebp+0x1234],0x56
        add     byte ptr [ebx+esi],0x56
        add     byte ptr [ebx+edi+0x34],0x56
        add     byte ptr [ebp+esi+0x1234],0x56
        add     word ptr [esi],0x1234
        add     word ptr [0x1234],0x1234
        add     word ptr [edi-0x34],0x1234
        add     word ptr [ebp+0x1234],0x1234
        add     word ptr [ebx+esi],0x1234
        add     word ptr [ebx+edi+0x34],0x1234
        add     word ptr [ebp+esi+0x1234],0x1234
        add     dword ptr [esi],0x12345678
        add     dword ptr [0x1234],0x12345678
        add     dword ptr [edi-0x34],0x12345678
        add     dword ptr [ebp+0x1234],0x12345678
        add     dword ptr [ebx+esi],0x12345678
        add     dword ptr [ebx+edi+0x34],0x12345678
        add     dword ptr [ebp+esi+0x1234],0x12345678
        add     eax,0x56
        add     eax,-16
        add     ecx,0x56
        add     ecx,-16
        add     dword ptr [esi],0x56
        add     dword ptr [0x1234],0x56
        add     dword ptr [edi-0x34],0x56
        add     dword ptr [ebp+0x1234],0x56
        add     dword ptr [ebx+esi],0x56
        add     dword ptr [ebx+edi+0x34],0x56
        add     dword ptr [ebp+esi+0x1234],0x56
;### Add with carry
        adc     [esi],dh
        adc     [0x1234],bh
        adc     [edi-0x34],al
        adc     [ebp+0x1234],cl
        adc     [ebx+esi],dl
        adc     [ebx+edi+0x34],bl
        adc     [ebp+esi+0x1234],ah
        adc     dh,[esi]
        adc     bh,[0x1234]
        adc     al,[edi-0x34]
        adc     cl,[ebp+0x1234]
        adc     dl,[ebx+esi]
        adc     bl,[ebx+edi+0x34]
        adc     ah,[ebp+esi+0x1234]
        adc     eax,ecx
        adc     edx,ebx
        adc     esp,ebp
        adc     [esi],esi
        adc     [0x1234],edi
        adc     [edi-0x34],eax
        adc     [ebp+0x1234],ecx
        adc     [ebx+esi],edx
        adc     [ebx+edi+0x34],ebx
        adc     [ebp+esi+0x1234],esp
        adc     esi,[esi]
        adc     edi,[0x1234]
        adc     eax,[edi-0x34]
        adc     ecx,[ebp+0x1234]
        adc     edx,[ebx+esi]
        adc     ebx,[ebx+edi+0x34]
        adc     esp,[ebp+esi+0x1234]
        adc     eax,0x12345678
        adc     ecx,0x12345678
        adc     byte ptr [esi],0x56
        adc     byte ptr [0x1234],0x56
        adc     byte ptr [edi-0x34],0x56
        adc     byte ptr [ebp+0x1234],0x56
        adc     byte ptr [ebx+esi],0x56
        adc     byte ptr [ebx+edi+0x34],0x56
        adc     byte ptr [ebp+esi+0x1234],0x56
        adc     word ptr [esi],0x1234
        adc     word ptr [0x1234],0x1234
        adc     word ptr [edi-0x34],0x1234
        adc     word ptr [ebp+0x1234],0x1234
        adc     word ptr [ebx+esi],0x1234
        adc     word ptr [ebx+edi+0x34],0x1234
        adc     word ptr [ebp+esi+0x1234],0x1234
        adc     dword ptr [esi],0x12345678
        adc     dword ptr [0x1234],0x12345678
        adc     dword ptr [edi-0x34],0x12345678
        adc     dword ptr [ebp+0x1234],0x12345678
        adc     dword ptr [ebx+esi],0x12345678
        adc     dword ptr [ebx+edi+0x34],0x12345678
        adc     dword ptr [ebp+esi+0x1234],0x12345678
        adc     eax,0x56
        adc     eax,-16
        adc     ecx,0x56
        adc     ecx,-16
        adc     dword ptr [esi],0x56
        adc     dword ptr [0x1234],0x56
        adc     dword ptr [edi-0x34],0x56
        adc     dword ptr [ebp+0x1234],0x56
        adc     dword ptr [ebx+esi],0x56
        adc     dword ptr [ebx+edi+0x34],0x56
        adc     dword ptr [ebp+esi+0x1234],0x56
;### Increment by 1
        inc     ebp
        inc     dword ptr [esi]
        inc     dword ptr [0x1234]
        inc     dword ptr [edi-0x34]
        inc     dword ptr [ebp+0x1234]
        inc     dword ptr [ebx+esi]
        inc     dword ptr [ebx+edi+0x34]
        inc     dword ptr [ebp+esi+0x1234]
;### Subtraction
        sub     al,cl
        sub     dl,bl
        sub     ah,ch
        sub     [esi],dh
        sub     [0x1234],bh
        sub     [edi-0x34],al
        sub     [ebp+0x1234],cl
        sub     [ebx+esi],dl
        sub     [ebx+edi+0x34],bl
        sub     [ebp+esi+0x1234],ah
        sub     dh,[esi]
        sub     bh,[0x1234]
        sub     al,[edi-0x34]
        sub     cl,[ebp+0x1234]
        sub     dl,[ebx+esi]
        sub     bl,[ebx+edi+0x34]
        sub     ah,[ebp+esi+0x1234]
        sub     eax,ecx
        sub     edx,ebx
        sub     esp,ebp
        sub     [esi],esi
        sub     [0x1234],edi
        sub     [edi-0x34],eax
        sub     [ebp+0x1234],ecx
        sub     [ebx+esi],edx
        sub     [ebx+edi+0x34],ebx
        sub     [ebp+esi+0x1234],esp
        sub     esi,[esi]
        sub     edi,[0x1234]
        sub     eax,[edi-0x34]
        sub     ecx,[ebp+0x1234]
        sub     edx,[ebx+esi]
        sub     ebx,[ebx+edi+0x34]
        sub     esp,[ebp+esi+0x1234]
        sub     al,0x56
        sub     cl,0x56
        sub     byte ptr [esi],0x56
        sub     byte ptr [0x1234],0x56
        sub     byte ptr [edi-0x34],0x56
        sub     byte ptr [ebp+0x1234],0x56
        sub     byte ptr [ebx+esi],0x56
        sub     byte ptr [ebx+edi+0x34],0x56
        sub     byte ptr [ebp+esi+0x1234],0x56
        sub     eax,0x12345678
        sub     ecx,0x12345678
        sub     dword ptr [esi],0x12345678
        sub     dword ptr [0x1234],0x12345678
        sub     dword ptr [edi-0x34],0x12345678
        sub     dword ptr [ebp+0x1234],0x12345678
        sub     dword ptr [ebx+esi],0x12345678
        sub     dword ptr [ebx+edi+0x34],0x12345678
        sub     dword ptr [ebp+esi+0x1234],0x12345678
        sub     eax,0x56
        sub     eax,-16
        sub     ecx,0x56
        sub     ecx,-16
        sub     dword ptr [esi],0x56
        sub     dword ptr [0x1234],0x56
        sub     dword ptr [edi-0x34],0x56
        sub     dword ptr [ebp+0x1234],0x56
        sub     dword ptr [ebx+esi],0x56
        sub     dword ptr [ebx+edi+0x34],0x56
        sub     dword ptr [ebp+esi+0x1234],0x56
;### Subtract with borrow
        sbb     al,cl
        sbb     dl,bl
        sbb     ah,ch
        sbb     [esi],dh
        sbb     [0x1234],bh
        sbb     [edi-0x34],al
        sbb     [ebp+0x1234],cl
        sbb     [ebx+esi],dl
        sbb     [ebx+edi+0x34],bl
        sbb     [ebp+esi+0x1234],ah
        sbb     dh,[esi]
        sbb     bh,[0x1234]
        sbb     al,[edi-0x34]
        sbb     cl,[ebp+0x1234]
        sbb     dl,[ebx+esi]
        sbb     bl,[ebx+edi+0x34]
        sbb     ah,[ebp+esi+0x1234]
        sbb     eax,ecx
        sbb     edx,ebx
        sbb     esp,ebp
        sbb     [esi],esi
        sbb     [0x1234],edi
        sbb     [edi-0x34],eax
        sbb     [ebp+0x1234],ecx
        sbb     [ebx+esi],edx
        sbb     [ebx+edi+0x34],ebx
        sbb     [ebp+esi+0x1234],esp
        sbb     esi,[esi]
        sbb     edi,[0x1234]
        sbb     eax,[edi-0x34]
        sbb     ecx,[ebp+0x1234]
        sbb     edx,[ebx+esi]
        sbb     ebx,[ebx+edi+0x34]
        sbb     esp,[ebp+esi+0x1234]
        sbb     al,0x56
        sbb     cl,0x56
        sbb     byte ptr [esi],0x56
        sbb     byte ptr [0x1234],0x56
        sbb     byte ptr [edi-0x34],0x56
        sbb     byte ptr [ebp+0x1234],0x56
        sbb     byte ptr [ebx+esi],0x56
        sbb     byte ptr [ebx+edi+0x34],0x56
        sbb     byte ptr [ebp+esi+0x1234],0x56
        sbb     eax,0x12345678
        sbb     ecx,0x12345678
        sbb     dword ptr [esi],0x12345678
        sbb     dword ptr [0x1234],0x12345678
        sbb     dword ptr [edi-0x34],0x12345678
        sbb     dword ptr [ebp+0x1234],0x12345678
        sbb     dword ptr [ebx+esi],0x12345678
        sbb     dword ptr [ebx+edi+0x34],0x12345678
        sbb     dword ptr [ebp+esi+0x1234],0x12345678
        sbb     eax,0x56
        sbb     eax,-16
        sbb     ecx,0x56
        sbb     ecx,-16
        sbb     dword ptr [esi],0x56
        sbb     dword ptr [0x1234],0x56
        sbb     dword ptr [edi-0x34],0x56
        sbb     dword ptr [ebp+0x1234],0x56
        sbb     dword ptr [ebx+esi],0x56
        sbb     dword ptr [ebx+edi+0x34],0x56
        sbb     dword ptr [ebp+esi+0x1234],0x56
;### Decrement by 1
        dec     ebp
        dec     dword ptr [esi]
        dec     dword ptr [0x1234]
        dec     dword ptr [edi-0x34]
        dec     dword ptr [ebp+0x1234]
        dec     dword ptr [ebx+esi]
        dec     dword ptr [ebx+edi+0x34]
        dec     dword ptr [ebp+esi+0x1234]
;### Negation
        neg     ch
        neg     byte ptr [esi]
        neg     byte ptr [0x1234]
        neg     byte ptr [edi-0x34]
        neg     byte ptr [ebp+0x1234]
        neg     byte ptr [ebx+esi]
        neg     byte ptr [ebx+edi+0x34]
        neg     byte ptr [ebp+esi+0x1234]
        neg     ebp
        neg     dword ptr [esi]
        neg     dword ptr [0x1234]
        neg     dword ptr [edi-0x34]
        neg     dword ptr [ebp+0x1234]
        neg     dword ptr [ebx+esi]
        neg     dword ptr [ebx+edi+0x34]
        neg     dword ptr [ebp+esi+0x1234]
;### Compare operands
        cmp     [esi],dh
        cmp     [0x1234],bh
        cmp     [edi-0x34],al
        cmp     [ebp+0x1234],cl
        cmp     [ebx+esi],dl
        cmp     [ebx+edi+0x34],bl
        cmp     [ebp+esi+0x1234],ah
        cmp     dh,[esi]
        cmp     bh,[0x1234]
        cmp     al,[edi-0x34]
        cmp     cl,[ebp+0x1234]
        cmp     dl,[ebx+esi]
        cmp     bl,[ebx+edi+0x34]
        cmp     ah,[ebp+esi+0x1234]
        cmp     eax,ecx
        cmp     edx,ebx
        cmp     esp,ebp
        cmp     [esi],esi
        cmp     [0x1234],edi
        cmp     [edi-0x34],eax
        cmp     [ebp+0x1234],ecx
        cmp     [ebx+esi],edx
        cmp     [ebx+edi+0x34],ebx
        cmp     [ebp+esi+0x1234],esp
        cmp     esi,[esi]
        cmp     edi,[0x1234]
        cmp     eax,[edi-0x34]
        cmp     ecx,[ebp+0x1234]
        cmp     edx,[ebx+esi]
        cmp     ebx,[ebx+edi+0x34]
        cmp     esp,[ebp+esi+0x1234]
        cmp     eax,0x12345678
        cmp     ecx,0x12345678
        cmp     byte ptr [esi],0x56
        cmp     byte ptr [0x1234],0x56
        cmp     byte ptr [edi-0x34],0x56
        cmp     byte ptr [ebp+0x1234],0x56
        cmp     byte ptr [ebx+esi],0x56
        cmp     byte ptr [ebx+edi+0x34],0x56
        cmp     byte ptr [ebp+esi+0x1234],0x56
        cmp     word ptr [esi],0x1234
        cmp     word ptr [0x1234],0x1234
        cmp     word ptr [edi-0x34],0x1234
        cmp     word ptr [ebp+0x1234],0x1234
        cmp     word ptr [ebx+esi],0x1234
        cmp     word ptr [ebx+edi+0x34],0x1234
        cmp     word ptr [ebp+esi+0x1234],0x1234
        cmp     dword ptr [esi],0x12345678
        cmp     dword ptr [0x1234],0x12345678
        cmp     dword ptr [edi-0x34],0x12345678
        cmp     dword ptr [ebp+0x1234],0x12345678
        cmp     dword ptr [ebx+esi],0x12345678
        cmp     dword ptr [ebx+edi+0x34],0x12345678
        cmp     dword ptr [ebp+esi+0x1234],0x12345678
        cmp     eax,0x56
        cmp     eax,-16
        cmp     ecx,0x56
        cmp     ecx,-16
        cmp     dword ptr [esi],0x56
        cmp     dword ptr [0x1234],0x56
        cmp     dword ptr [edi-0x34],0x56
        cmp     dword ptr [ebp+0x1234],0x56
        cmp     dword ptr [ebx+esi],0x56
        cmp     dword ptr [ebx+edi+0x34],0x56
        cmp     dword ptr [ebp+esi+0x1234],0x56
;### Unesigned multiply
        mul     ch
        mul     byte ptr [esi]
        mul     byte ptr [0x1234]
        mul     byte ptr [edi-0x34]
        mul     byte ptr [ebp+0x1234]
        mul     byte ptr [ebx+esi]
        mul     byte ptr [ebx+edi+0x34]
        mul     byte ptr [ebp+esi+0x1234]
        mul     ebp
        mul     dword ptr [esi]
        mul     dword ptr [0x1234]
        mul     dword ptr [edi-0x34]
        mul     dword ptr [ebp+0x1234]
        mul     dword ptr [ebx+esi]
        mul     dword ptr [ebx+edi+0x34]
        mul     dword ptr [ebp+esi+0x1234]
;### Esigned multiply
        imul    ch
        imul    byte ptr [esi]
        imul    byte ptr [0x1234]
        imul    byte ptr [edi-0x34]
        imul    byte ptr [ebp+0x1234]
        imul    byte ptr [ebx+esi]
        imul    byte ptr [ebx+edi+0x34]
        imul    byte ptr [ebp+esi+0x1234]
        imul    ebp
        imul    dword ptr [esi]
        imul    dword ptr [0x1234]
        imul    dword ptr [edi-0x34]
        imul    dword ptr [ebp+0x1234]
        imul    dword ptr [ebx+esi]
        imul    dword ptr [ebx+edi+0x34]
        imul    dword ptr [ebp+esi+0x1234]
;### Unesigned edivide
        div     eax,ebp
        div     eax,dword ptr [esi]
        div     eax,dword ptr [0x1234]
        div     eax,dword ptr [edi-0x34]
        div     eax,dword ptr [ebp+0x1234]
        div     eax,dword ptr [ebx+esi]
        div     eax,dword ptr [ebx+edi+0x34]
