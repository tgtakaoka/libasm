        repne   scasd
        repnz   movsd
        repnz   cmpsd
        repnz   stosd
        repnz   lodsd
        repnz   scasd
;### Move dword from string to string
        movsd   es:[edi], ds:[esi]
;### Compare dwords in memory
        cmpsd   ds:[esi], es:[edi]
;### Compare dword string
        scasd   es:[edi]
;### Load string dword
        lodsd   ds:[esi]
;### Store dword string
        stosd   es:[edi]
;### Control transfer
;### Call procedure
        call    eax
        call    esi
;#        call    $+0x12345678     rel32?
        call    [esi]
        call    [0x1234]
        call    [edi-0x34]
        call    [ebp+0x1234]
        call    [ebx+esi]
        call    [ebx+edi+0x34]
        call    [ebp+esi+0x1234]
        lcall   0x5678, 0x1234
        lcall   [esi]
        lcall   [0x1234]
        lcall   [edi-0x34]
        lcall   [ebp+0x1234]
        lcall   [ebx+esi]
        lcall   [ebx+edi+0x34]
        lcall   [ebp+esi+0x1234]
;### Jump
        jmp     $+0x12345678
        jmp     eax
        jmp     esi
        jmp     [esi]
        jmp     [0x1234]
        jmp     [edi-0x34]
        jmp     [ebp+0x1234]
        jmp     [ebx+esi]
        jmp     [ebx+edi+0x34]
        jmp     [ebp+esi+0x1234]
        ljmp    0x5678, 0x1234
        ljmp    [esi]
        ljmp    [0x1234]
        ljmp    [edi-0x34]
        ljmp    [ebp+0x1234]
        ljmp    [ebx+esi]
        ljmp    [ebx+edi+0x34]
        ljmp    [ebp+esi+0x1234]
;### Return from procedure
        retd
        retd    16
;### Jump on Equal/Zero
        je      $
        jz      $
;### Jump on Less/Not Greater or Equal
        jl      $
        jnge    $
;### Jump on Less or Equal/Not Greater
        jle     $
        jng     $
;### Jump on Below/Not Above or Equal/Carry
        jb      $
        jnae    $
        jc      $
;### Jump on Below or Equal/Not Above
        jbe     $
        jna     $
;### Jump on Parity/Parity Even
        jpe     $
        jp      $
;### Jump on Overflow
        jo      $
;### Jump on Esign
        js      $
;### Jump on Not Equal/Not Zero
        jne     $
        jnz     $
;### Jump on Not Less/Greater or Equal
        jge     $
        jnl     $
;### Jump on Not Less or Equal/Greater
        jg      $
        jnle    $
;### Jump on Not Below/Above or Equal/Not Carry
        jae     $
        jnb     $
        jnc     $
;### Jump on Not Below or Equal/Above
        ja      $
        jnbe    $
;### Jump on Not Parity/Parity Odd
        jpo     $
        jnp     $
;### Jump on Not Overflow
        jno     $
;### Jump on Not Esign
        jns     $
;### Loop ECX Times
        loop    $
;### Loop While Zero/Equal
        loope   $
        loopz   $
;### Loop While Not Zero/Equal
        loopne  $
        loopnz  $
;### Jump if ECX is zero
        jecxz    $
;### Return from interrupt
        iretd
;### Check array index
        bound   esi, [esi]
        bound   edi, [0x1234]
        bound   eax, [edi+52]
        bound   ecx, [ebp+0x1234]
        bound   edx, [ebx+esi]
        bound   ebx, [ebx+edi+52]
        bound   esp, [ebp+esi+0x1234]
;### Bit scan forward
        bsf     si, [si]
        bsf     di, [0x1234]
        bsf     ax, [di+52]
        bsf     cx, [bp+0x1234]
        bsf     dx, [bx+si]
        bsf     bx, [bx+di+52]
        bsf     sp, [bp+si+0x1234]
        bsf     esi, [esi]
        bsf     edi, [0x1234]
        bsf     eax, [edi+52]
        bsf     ecx, [ebp+0x1234]
        bsf     edx, [ebx+esi]
        bsf     ebx, [ebx+edi+52]
        bsf     esp, [ebp+esi+0x1234]
;### Bit scan reverse
        bsr     si, [si]
        bsr     di, [0x1234]
        bsr     ax, [di+52]
        bsr     cx, [bp+0x1234]
        bsr     dx, [bx+si]
        bsr     bx, [bx+di+52]
        bsr     sp, [bp+si+0x1234]
        bsr     esi, [esi]
        bsr     edi, [0x1234]
        bsr     eax, [edi+52]
        bsr     ecx, [ebp+0x1234]
        bsr     edx, [ebx+esi]
        bsr     ebx, [ebx+edi+52]
        bsr     esp, [ebp+esi+0x1234]
;### Bit test
        bt      [si], si
        bt      [0x1234], di
        bt      [di+52], ax
        bt      [bp+0x1234], cx
        bt      [bx+si], dx
        bt      [bx+di+52], bx
        bt      [bp+si+0x1234], sp
        bt      [esi], esi
        bt      [0x1234], edi
        bt      [edi+52], eax
        bt      [ebp+0x1234], ecx
        bt      [ebx+esi], edx
        bt      [ebx+edi+52], ebx
        bt      [ebp+esi+0x1234], esp
;### Bit test and complement
        btc     [si], si
        btc     [0x1234], di
        btc     [di+52], ax
        btc     [bp+0x1234], cx
        btc     [bx+si], dx
        btc     [bx+di+52], bx
        btc     [bp+si+0x1234], sp
        btc     [esi], esi
        btc     [0x1234], edi
        btc     [edi+52], eax
        btc     [ebp+0x1234], ecx
        btc     [ebx+esi], edx
        btc     [ebx+edi+52], ebx
        btc     [ebp+esi+0x1234], esp
;### Bit test and reset
        btr     [si], si
        btr     [0x1234], di
        btr     [di+52], ax
        btr     [bp+0x1234], cx
        btr     [bx+si], dx
        btr     [bx+di+52], bx
        btr     [bp+si+0x1234], sp
        btr     [esi], esi
        btr     [0x1234], edi
        btr     [edi+52], eax
        btr     [ebp+0x1234], ecx
        btr     [ebx+esi], edx
        btr     [ebx+edi+52], ebx
        btr     [ebp+esi+0x1234], esp
        btr     word ptr [si], 0x56
        btr     word ptr [0x1234], 0x56
        btr     word ptr [di+52], 0x56
        btr     word ptr [bp+0x1234], 0x56
        btr     word ptr [bx+si], 0x56
        btr     word ptr [bx+di+52], 0x56
        btr     word ptr [bp+si+0x1234], 0x56
        btr     dword ptr [esi], 0x56
        btr     dword ptr [0x1234], 0x56
        btr     dword ptr [edi+52], 0x56
        btr     dword ptr [ebp+0x1234], 0x56
        btr     dword ptr [ebx+esi], 0x56
        btr     dword ptr [ebx+edi+52], 0x56
        btr     dword ptr [ebp+esi+0x1234], 0x56
;### Bit test and set
        btr     [si], si
        btr     [0x1234], di
        btr     [di+52], ax
        btr     [bp+0x1234], cx
        btr     [bx+si], dx
        btr     [bx+di+52], bx
