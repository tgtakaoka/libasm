        btr     word ptr [bp+0x1234], 0x56
        btr     word ptr [bx+si], 0x56
        btr     word ptr [bx+di+52], 0x56
        btr     word ptr [bp+si+0x1234], 0x56
        btr     dword ptr [esi], 0x56
        btr     dword ptr [0x1234], 0x56
        btr     dword ptr [edi+52], 0x56
        btr     dword ptr [ebp+0x1234], 0x56
        btr     dword ptr [ebx+esi], 0x56
        btr     dword ptr [ebx+edi+52], 0x56
        btr     dword ptr [ebp+esi+0x1234], 0x56
;### Segment override
        mov     fs:[bx],eax
        mov     fs:[bp],eax
        mov     fs:[si],eax
        mov     fs:[di],eax
        mov     fs:[0x1234],eax
        mov     gs:[bx],eax
        mov     gs:[bp],eax
        mov     gs:[si],eax
        mov     gs:[di],eax
        mov     gs:[0x1234],eax
        jmp     fs:[si]
        jmp     gs:[si]
        mov     es:[ebx],eax
        mov     es:[ebp],eax
        mov     es:[esi],eax
        mov     es:[edi],eax
        mov     es:[0x1234],eax
        mov     cs:[ebx],eax
        mov     cs:[ebp],eax
